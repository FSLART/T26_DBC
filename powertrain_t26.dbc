CM_ SG_ 3221225472 CMD_MaxAcBrakeCurrent "Minimum AC current value depends on inverter configuration!";
CM_ SG_ 3221225472 ControlMode "1: CONTROL_MODE_SPEED
2: CONTROL_MODE_CURRENT
3: CONTROL_MODE_CURRENT_BRAKE
4: CONTROL_MODE_POS
7: CONTROL_MODE_NONE
0, 5, 6: NOT USED
";
CM_ SG_ 3221225472 TargetIq "The value represent how much Iq current the inverter is targeted to reach. This value excludes limits. For ex. if the target Iq is 50 A and temperature limit is hit, the values keep 50 A in any case, not including the deration of the temp. limit. This is useful in multi-inverter configuration to let know the secondary inverter the target Iq. ";
CM_ SG_ 3221225472 MotorPosition "Motor position expressed in degrees.";
CM_ SG_ 3221225472 isMotorStill "Represents if the motor in still position or not. 1: still, 0: rotating";
CM_ SG_ 3221225472 CMD_SetDigOutput1 "0: OFF
1: ON";
CM_ SG_ 3221225472 CMD_SetDigOutput2 "0: OFF
1: ON";
CM_ SG_ 3221225472 CMD_SetDigOutput3 "0: OFF
1: ON";
CM_ SG_ 3221225472 CMD_SetDigOutput4 "0: OFF
1: ON";
CM_ SG_ 3221225472 CMD_MaxDcBrakeCurrent "Minimum DC current value depends on inverter configuration!";
CM_ SG_ 3221225472 MaxAcCurrent "Max AC current configured with the DTI CAN tool.";
CM_ SG_ 3221225472 AvailableMaxAcCurrent "Available max AC current. This value affected by the limitation functions (igbt temp, motortemp etc.) Defines how much current available from the configured one.";
CM_ SG_ 3221225472 MinAcCurrent "Min AC current configured with the DTI CAN tool.";
CM_ SG_ 3221225472 AvailableMinAcCurrent "Available min AC current. This value affected by the limitation functions (igbt temp, motortemp etc.) Defines how much current available from the configured one.";
CM_ SG_ 3221225472 MaxDcCurrent "Max DC current configured with the DTI CAN tool.";
CM_ SG_ 3221225472 AvailableMaxDcCurrent "Available max DC current. This value affected by the limitation functions (igbt temp, motortemp etc.) Defines how much current available from the configured one.";
CM_ SG_ 3221225472 MinDcCurrent "Min DC current configured with the DTI CAN tool.";
CM_ SG_ 3221225472 AvailableMinDcCurrent "Available min DC current. This value affected by the limitation functions (igbt temp, motortemp etc.) Defines how much current available from the configured one.";
CM_ SG_ 3221225472 CMD_TargetBrakeCurrent "Max AC brake current depends on configuration!";
